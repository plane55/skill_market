---
import { skills as allSkillsData, getSkillBySlug, getSkills } from '../../../i18n/skills'

export function getStaticPaths() {
  const paths = []
  for (const locale of ['zh', 'en']) {
    for (const skill of allSkillsData) {
      paths.push({ params: { locale, slug: skill.slug } })
    }
  }
  return paths
}

const { locale, slug } = Astro.params
const skill = getSkillBySlug(slug, locale)
const isEn = locale === 'en'

if (!skill) {
  return Astro.redirect(`/${locale}`)
}

const prefix = `${import.meta.env.BASE_URL}/${locale}`

const categoryColors = {
  ai: 'bg-blue-100 text-blue-700',
  programming: 'bg-blue-100 text-blue-700',
  design: 'bg-pink-100 text-pink-700',
  writing: 'bg-orange-100 text-orange-700',
  marketing: 'bg-green-100 text-green-700',
  management: 'bg-cyan-100 text-cyan-700',
  data: 'bg-yellow-100 text-yellow-700',
  language: 'bg-teal-100 text-teal-700',
  growth: 'bg-rose-100 text-rose-700',
}

const categoryNameMap = {
  ai: { zh: 'AI / 大模型', en: 'AI / LLM' },
  programming: { zh: '编程开发', en: 'Programming' },
  design: { zh: 'UI/UX 设计', en: 'UI/UX Design' },
  writing: { zh: '内容创作', en: 'Content Creation' },
  marketing: { zh: '市场营销', en: 'Marketing' },
  management: { zh: '管理', en: 'Management' },
  data: { zh: '数据分析', en: 'Data Analysis' },
  language: { zh: '语言学习', en: 'Language' },
  growth: { zh: '个人成长', en: 'Personal Growth' },
}

const difficultyMap = {
  1: { label: { zh: '初级', en: 'Beginner' }, cls: 'text-emerald-600 bg-emerald-50' },
  2: { label: { zh: '中级', en: 'Intermediate' }, cls: 'text-amber-600 bg-amber-50' },
  3: { label: { zh: '高级', en: 'Advanced' }, cls: 'text-rose-600 bg-rose-50' },
}

const catName = categoryNameMap[skill.category]?.[locale] || ''
const catColor = categoryColors[skill.category] || 'bg-slate-100 text-slate-600'
const diff = difficultyMap[skill.difficulty] || difficultyMap[1]
const stars = Math.round(skill.rating)
const otherLocale = isEn ? 'zh' : 'en'
const otherPrefix = `${import.meta.env.BASE_URL}/${otherLocale}`

const allSkills = getSkills(locale)
const relatedSkills = allSkills
  .filter(s => s.category === skill.category && s.id !== skill.id)
  .slice(0, 4)

const brand = isEn ? 'SkillMarket' : 'Skill市场'

const t = {
  home: isEn ? 'Home' : '首页',
  featured: isEn ? 'Featured' : '精选推荐',
  followers: isEn ? 'followers' : '人关注',
  reviews: isEn ? 'reviews' : '评价',
  expert: isEn ? 'Expert' : '技能专家',
  related: isEn ? 'Related Skills' : '同分类技能',
  viewAll: isEn ? 'View All →' : '查看全部 →',
  browse: isEn ? 'Browse Skills' : '浏览课程',
}
---

<!DOCTYPE html>
<html lang={isEn ? 'en' : 'zh-CN'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{skill.name} — {brand}</title>
  <meta name="description" content={skill.description} />
  <meta property="og:title" content={`${skill.name} — ${brand}`} />
  <meta property="og:description" content={skill.description} />
  <meta property="og:type" content="article" />
  <link rel="alternate" hreflang={otherLocale} href={`${otherPrefix}/skills/${skill.slug}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-800 antialiased font-sans">

  <nav class="fixed top-0 left-0 right-0 z-50 glass-nav shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 sm:h-20">
        <a href={prefix} class="flex items-center gap-2.5">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center text-white text-lg font-bold shadow-lg shadow-blue-200">S</div>
          <span class="text-xl font-bold gradient-text hidden sm:block">{brand}</span>
        </a>
        <div class="flex items-center gap-3">
          <a href={`${otherPrefix}/skills/${skill.slug}`} class="text-xs sm:text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors">
            {isEn ? '中文' : 'English'}
          </a>
        </div>
      </div>
    </div>
  </nav>

  <div class="pt-24 sm:pt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8">
        <a href={prefix} class="hover:text-blue-600 transition-colors">{t.home}</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <a href={`${prefix}#${skill.category}`} class="hover:text-blue-600 transition-colors">{catName}</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        <span class="text-slate-600">{skill.name}</span>
      </nav>
    </div>
  </div>

  <section class="relative pb-16 overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute -top-20 -right-20 w-[400px] h-[400px] bg-blue-200/30 rounded-full mix-blend-multiply blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] bg-blue-200/30 rounded-full mix-blend-multiply blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            {skill.featured ? (
              <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-semibold text-amber-600 bg-amber-50 rounded-full">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {t.featured}
              </span>
            ) : null}
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-800 mb-4">{skill.name}</h1>
          <p class="text-lg text-slate-500 leading-relaxed mb-6 max-w-2xl">{skill.description}</p>

          <div class="flex items-center gap-3 mb-8 flex-wrap">
            <span class={`px-3 py-1 text-sm font-medium rounded-full ${catColor}`}>{catName}</span>
            <span class={`px-3 py-1 text-sm font-medium rounded-full ${diff.cls}`}>{diff.label[locale]}</span>
          </div>

          <div class="flex items-center gap-6 mb-8 flex-wrap">
            <div class="flex items-center gap-1.5">
              <div class="flex items-center">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class={`w-4 h-4 ${i < stars ? 'text-amber-400' : 'text-slate-200'}`} viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
              <span class="text-lg font-bold text-slate-700">{skill.rating}</span>
              <span class="text-sm text-slate-400">({skill.reviewCount} {t.reviews})</span>
            </div>
            <div class="flex items-center gap-1.5 text-slate-500">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
              <span class="text-sm">{skill.enrolledCount >= 1000 ? (skill.enrolledCount / 1000).toFixed(1) + 'k' : skill.enrolledCount} {t.followers}</span>
            </div>
          </div>

          <div class="glass rounded-2xl p-5 sm:p-6 inline-flex items-center gap-4">
            <div>
              <div class="text-lg font-semibold text-slate-800">{skill.author.name}</div>
              <div class="text-sm text-slate-400">{t.expert}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {relatedSkills.length > 0 ? (
    <section class="py-12 sm:py-16 bg-white/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-800">{t.related}</h2>
          <a href={prefix} class="text-sm font-medium text-blue-600 hover:text-blue-700 transition-colors">{t.viewAll}</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6">
          {relatedSkills.map(s => (
            <a href={`${prefix}/skills/${s.slug}`} class="block group glass rounded-2xl p-5 sm:p-6 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-slate-200/60">
              <div class="flex items-start mb-3">
                {s.featured ? (
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-semibold text-amber-600 bg-amber-50 rounded-full">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {isEn ? 'Featured' : '精选'}
                  </span>
                ) : null}
              </div>
              <h3 class="text-base sm:text-lg font-semibold text-slate-800 mb-2 group-hover:text-blue-600 transition-colors line-clamp-1">{s.name}</h3>
              <p class="text-sm text-slate-500 leading-relaxed mb-4 line-clamp-2">{s.description}</p>
              <div class="flex items-center gap-2 mb-4 flex-wrap">
                <span class={`px-2.5 py-0.5 text-xs font-medium rounded-full ${catColor}`}>{catName}</span>
                <span class={`px-2.5 py-0.5 text-xs font-medium rounded-full ${difficultyMap[s.difficulty]?.cls || 'text-emerald-600 bg-emerald-50'}`}>{difficultyMap[s.difficulty]?.label?.[locale] || '初级'}</span>
              </div>
              <div class="flex items-center gap-1.5">
                <div class="flex items-center">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg class={`w-3.5 h-3.5 ${i < Math.round(s.rating) ? 'text-amber-400' : 'text-slate-200'}`} viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  ))}
                </div>
                <span class="text-sm font-semibold text-slate-700">{s.rating}</span>
                <span class="text-xs text-slate-400">({s.reviewCount} {isEn ? 'reviews' : '评'})</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ) : null}

  <footer class="border-t border-slate-200/60 bg-white/80">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href={prefix} class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center text-white font-bold text-sm">S</div>
          <span class="text-lg font-bold gradient-text">{brand}</span>
        </a>
        <p class="text-sm text-slate-400">&copy; 2026 SkillMarket. All rights reserved.</p>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
  .gradient-text {
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-image: linear-gradient(to right, #4f46e5, #9333ea);
  }
  .glass {
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.18);
  }
  .glass-nav {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(226, 232, 240, 0.6);
  }
</style>
