---
import '../../styles/global.css'
import NavBar from '../../components/NavBar.astro'
import CategoryNav from '../../components/CategoryNav.astro'
import SkillCard from '../../components/SkillCard.astro'
import FooterSection from '../../components/FooterSection.astro'
import { getSkills } from '../../i18n/skills'
import { getCategories } from '../../i18n/ui'

const locale = 'en'
const skills = getSkills(locale)
const categories = getCategories(locale)

const labels = {
  all: 'All Skills',
  courses: 'skills',
  ai: 'AI / LLM Skills',
  programming: 'Programming Skills',
  design: 'UI/UX Design Skills',
  writing: 'Content Creation Skills',
  marketing: 'Marketing Skills',
  management: 'Management Skills',
  data: 'Data Analysis Skills',
  language: 'Language Learning Skills',
  growth: 'Personal Growth Skills',
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SkillMarket — Discover Your Next Skill</title>
  <meta name="description" content="SkillMarket brings together premium skills across AI/LLM, programming, design, marketing, and more. Discover your next skill and level up fast." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://skillmarket.example.com/en" />
  <meta property="og:title" content="SkillMarket — Discover Your Next Skill" />
  <meta property="og:description" content="Premium skills from industry experts to accelerate your career growth." />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-800 antialiased font-sans">
  <NavBar locale={locale} />

  <div class="pt-20 sm:pt-24">
    <CategoryNav categories={categories} locale={locale} />
  </div>

  <section class="pb-16 sm:pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 id="category-title" class="text-2xl sm:text-3xl font-bold text-slate-800">{labels.all}</h2>
          <p id="category-count" class="text-sm text-slate-400 mt-1">共 {skills.length} skills</p>
        </div>
      </div>

      <div id="skills-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6">
        {skills.map((skill, i) => (
          <div
            data-category={skill.category}
            class="animate-fade-in"
            style={`animation-delay:${(i % 8) * 0.06}s`}
          >
            <SkillCard skill={skill} locale={locale} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <FooterSection categories={categories} locale={locale} />
</body>
</html>

<script>
  const labels = {
    all: 'All Skills',
    courses: 'skills',
    ai: 'AI / LLM Skills',
    programming: 'Programming Skills',
    design: 'UI/UX Design Skills',
    writing: 'Content Creation Skills',
    marketing: 'Marketing Skills',
    management: 'Management Skills',
    data: 'Data Analysis Skills',
    language: 'Language Learning Skills',
    growth: 'Personal Growth Skills',
  };

  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('[data-filter]');
    const cards = document.querySelectorAll('[data-category]');
    const titleEl = document.getElementById('category-title');
    const countEl = document.getElementById('category-count');

    const activeClasses = ['bg-gradient-to-r', 'from-indigo-600', 'to-purple-600', 'text-white', 'shadow-lg', 'shadow-indigo-200/40', 'scale-105'];
    const inactiveClasses = ['bg-white', 'text-slate-600', 'border', 'border-slate-200/70'];

    function setActive(btn) {
      buttons.forEach(b => {
        b.classList.remove(...activeClasses);
        b.classList.add(...inactiveClasses);
      });
      btn.classList.remove(...inactiveClasses);
      btn.classList.add(...activeClasses);
    }

    function filter(cat) {
      let count = 0;
      cards.forEach(card => {
        const match = cat === 'all' || card.dataset.category === cat;
        card.classList.toggle('hidden', !match);
        if (match) count++;
      });
      titleEl.textContent = labels[cat] || labels.all;
      countEl.textContent = `共 ${count} skills`;
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        setActive(btn);
        filter(btn.dataset.filter);
      });
    });
  });
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
