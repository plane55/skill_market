---
import '../styles/global.css'
import NavBar from '../components/NavBar.astro'
import CategoryNav from '../components/CategoryNav.astro'
import SkillCard from '../components/SkillCard.astro'
import FooterSection from '../components/FooterSection.astro'
import { getSkills } from '../i18n/skills'
import { getCategories } from '../i18n/ui'

const locale = Astro.currentLocale || 'zh'
const skills = getSkills(locale)
const categories = getCategories(locale)

const filterLabels = {
  zh: {
    all: '全部技能',
    courses: '个技能',
    ai: 'AI / 大模型 技能',
    programming: '编程开发 技能',
    design: 'UI/UX 设计 技能',
    writing: '内容创作 技能',
    marketing: '市场营销 技能',
    management: '管理 技能',
    data: '数据分析 技能',
    language: '语言学习 技能',
    growth: '个人成长 技能',
  },
  en: {
    all: 'All Skills',
    courses: 'skills',
    ai: 'AI / LLM Skills',
    programming: 'Programming Skills',
    design: 'UI/UX Design Skills',
    writing: 'Content Creation Skills',
    marketing: 'Marketing Skills',
    management: 'Management Skills',
    data: 'Data Analysis Skills',
    language: 'Language Learning Skills',
    growth: 'Personal Growth Skills',
  },
}

const labels = filterLabels[locale] || filterLabels.zh
---

<!DOCTYPE html>
<html lang={locale === 'en' ? 'en' : 'zh-CN'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{locale === 'en' ? 'SkillMarket — Discover Your Next Skill' : 'SkillMarket — 发现属于你的下一个技能'}</title>
  <meta name="description" content={locale === 'en' ? 'SkillMarket brings together premium skills across AI/LLM, programming, design, marketing, and more.' : 'SkillMarket 汇聚 AI/大模型、编程开发、UI/UX 设计、内容创作、市场营销等各领域精品技能。发现属于你的下一个技能，快速进阶。'} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={locale === 'en' ? 'https://skillmarket.example.com/en' : 'https://skillmarket.example.com'} />
  <meta property="og:title" content={locale === 'en' ? 'SkillMarket — Discover Your Next Skill' : 'SkillMarket — 发现属于你的下一个技能'} />
  <meta property="og:description" content={locale === 'en' ? 'Premium skills from industry experts to accelerate your career growth.' : '汇聚各领域专家的实战技能，助你快速进阶。'} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'zh_CN'} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-800 antialiased font-sans">
  <NavBar locale={locale} />

  <div class="pt-20 sm:pt-24">
    <CategoryNav categories={categories} locale={locale} />
  </div>

  <section class="pb-16 sm:pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 id="category-title" class="text-2xl sm:text-3xl font-bold text-slate-800">{labels.all}</h2>
          <p id="category-count" class="text-sm text-slate-400 mt-1">{labels.courses.replace('{count}', skills.length)}</p>
        </div>
      </div>

      <div id="skills-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6">
        {skills.map((skill, i) => (
          <div
            data-category={skill.category}
            class="animate-fade-in"
            style={`animation-delay:${(i % 8) * 0.06}s`}
          >
            <SkillCard skill={skill} locale={locale} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <FooterSection categories={categories} locale={locale} />
</body>
</html>

<script>
  const labels = JSON.parse(document.getElementById('filter-labels')?.textContent || '{}');
  if (!Object.keys(labels).length) {
    const isEn = document.documentElement.lang === 'en';
    labels.all = isEn ? 'All Skills' : '全部技能';
    labels.courses = isEn ? 'skills' : '个技能';
    labels.ai = isEn ? 'AI / LLM Skills' : 'AI / 大模型 技能';
    labels.programming = isEn ? 'Programming Skills' : '编程开发 技能';
    labels.design = isEn ? 'UI/UX Design Skills' : 'UI/UX 设计 技能';
    labels.writing = isEn ? 'Content Creation Skills' : '内容创作 技能';
    labels.marketing = isEn ? 'Marketing Skills' : '市场营销 技能';
    labels.management = isEn ? 'Management Skills' : '管理 技能';
    labels.data = isEn ? 'Data Analysis Skills' : '数据分析 技能';
    labels.language = isEn ? 'Language Learning Skills' : '语言学习 技能';
    labels.growth = isEn ? 'Personal Growth Skills' : '个人成长 技能';
  }

  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('[data-filter]');
    const cards = document.querySelectorAll('[data-category]');
    const titleEl = document.getElementById('category-title');
    const countEl = document.getElementById('category-count');

    const activeClasses = ['bg-gradient-to-r', 'from-indigo-600', 'to-purple-600', 'text-white', 'shadow-lg', 'shadow-indigo-200/40', 'scale-105'];
    const inactiveClasses = ['bg-white', 'text-slate-600', 'border', 'border-slate-200/70'];

    function setActive(btn) {
      buttons.forEach(b => {
        b.classList.remove(...activeClasses);
        b.classList.add(...inactiveClasses);
      });
      btn.classList.remove(...inactiveClasses);
      btn.classList.add(...activeClasses);
    }

    function filter(cat) {
      let count = 0;
      cards.forEach(card => {
        const match = cat === 'all' || card.dataset.category === cat;
        card.classList.toggle('hidden', !match);
        if (match) count++;
      });
      titleEl.textContent = labels[cat] || labels.all;
      countEl.textContent = `${labels.courses.replace('{count}', count)}`;
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        setActive(btn);
        filter(btn.dataset.filter);
      });
    });
  });
</script>

<!-- Pass labels to script -->
<script type="application/json" id="filter-labels">{JSON.stringify(labels)}</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
