---
const { categories, locale = 'zh' } = Astro.props

const texts = {
  zh: {
    tagline: '汇聚各领域专家的实战技能，',
    tagline2: '助你发现属于你的下一个技能。',
    links: '快速链接',
    discover: '发现技能',
    about: '关于我们',
    help: '帮助中心',
    popular: '热门分类',
    aboutTitle: '关于',
    privacy: '隐私政策',
    terms: '服务条款',
    copyright: '© 2026 Skill市场. All rights reserved.',
  },
  en: {
    tagline: 'Premium skills from industry experts,',
    tagline2: 'helping you discover your next skill.',
    links: 'Quick Links',
    discover: 'Discover',
    about: 'About',
    help: 'Help Center',
    popular: 'Popular Categories',
    aboutTitle: 'About',
    privacy: 'Privacy Policy',
    terms: 'Terms of Service',
    copyright: '© 2026 SkillMarket. All rights reserved.',
  },
}

const t = texts[locale] || texts.zh
const brand = locale === 'en' ? 'SkillMarket' : 'Skill市场'
---

<footer class="bg-slate-900 text-slate-400 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 sm:gap-12">
      <div class="col-span-2 sm:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 flex items-center justify-center text-white text-sm font-bold">S</div>
          <span class="text-lg font-bold text-white">{brand}</span>
        </div>
        <p class="text-sm leading-relaxed text-slate-500">
          {t.tagline}<br />{t.tagline2}
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-white mb-4">{t.links}</h4>
        <ul class="space-y-2.5">
          <li><a href="#" class="text-sm hover:text-blue-400 transition-colors">{t.discover}</a></li>
          <li><a href="#" class="text-sm hover:text-blue-400 transition-colors">{t.about}</a></li>
          <li><a href="#" class="text-sm hover:text-blue-400 transition-colors">{t.help}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-white mb-4">{t.popular}</h4>
        <ul class="space-y-2.5">
          {categories.slice(1, 7).map(cat => (
            <li><a href="#" class="text-sm hover:text-blue-400 transition-colors">{cat.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-white mb-4">{t.aboutTitle}</h4>
        <ul class="space-y-2.5">
          <li><a href="#" class="text-sm hover:text-blue-400 transition-colors">{t.privacy}</a></li>
          <li><a href="#" class="text-sm hover:text-blue-400 transition-colors">{t.terms}</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500">
        <p>{t.copyright}</p>
      </div>
    </div>
  </div>
</footer>
