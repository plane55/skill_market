---
const { plugin, locale = 'zh' } = Astro.props
const prefix = `${import.meta.env.BASE_URL}/${locale}`

const categoryColors = {
  search: 'bg-blue-100 text-blue-700',
  productivity: 'bg-amber-100 text-amber-700',
  media: 'bg-pink-100 text-pink-700',
  dev: 'bg-purple-100 text-purple-700',
  data: 'bg-yellow-100 text-yellow-700',
  communication: 'bg-green-100 text-green-700',
}

const categoryNames = {
  search: { zh: '搜索', en: 'Search' },
  productivity: { zh: '效率', en: 'Productivity' },
  media: { zh: '媒体', en: 'Media' },
  dev: { zh: '开发', en: 'Dev' },
  data: { zh: '数据', en: 'Data' },
  communication: { zh: '通讯', en: 'Communication' },
}

const catName = categoryNames[plugin.category]?.[locale] || ''
const catColor = categoryColors[plugin.category] || 'bg-slate-100 text-slate-600'
const stars = Math.round(plugin.rating)
const featureText = locale === 'en' ? 'Featured' : '精选推荐'
const reviewText = locale === 'en' ? 'reviews' : '评价'
---

<a href={`${prefix}/plugins/${plugin.slug}`} class="block group glass rounded-2xl p-5 sm:p-6 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-slate-200/60 dark:hover:shadow-slate-900/60 cursor-pointer">
  {plugin.featured ? (
    <div class="flex items-center mb-3">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-semibold text-amber-600 bg-amber-50 rounded-full">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {featureText}
      </span>
    </div>
  ) : null}

  <h3 class="text-base sm:text-lg font-semibold text-slate-800 dark:text-slate-100 mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-1">{plugin.name}</h3>

  <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-4 line-clamp-2">{plugin.description}</p>

  <div class="flex items-center gap-2 mb-4 flex-wrap">
    <span class={`px-2.5 py-0.5 text-xs font-medium rounded-full ${catColor}`}>{catName}</span>
    <span class="px-2.5 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300">v{plugin.version}</span>
  </div>

  <div class="flex items-center gap-1.5 mb-4">
    <div class="flex items-center">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg class={`w-3.5 h-3.5 ${i < stars ? 'text-amber-400' : 'text-slate-200'}`} viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
    </div>
    <span class="text-sm font-semibold text-slate-700 dark:text-slate-300">{plugin.rating}</span>
    <span class="text-xs text-slate-400 dark:text-slate-500">({plugin.reviewCount} {reviewText})</span>
  </div>

  <div class="flex items-center flex-wrap gap-1.5 pt-4 border-t border-slate-100 dark:border-slate-700">
    {plugin.platform.map(p => (
      <span class="px-2 py-0.5 text-xs font-medium text-slate-500 bg-slate-100 rounded-md dark:text-slate-400 dark:bg-slate-700">{p}</span>
    ))}
  </div>
</a>
