---
const { categories, locale = 'zh' } = Astro.props
---

<section class="py-6 sm:py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center gap-2 sm:gap-3">
      {categories.map((cat, i) => (
        <button
          data-filter={cat.id}
          class={`flex items-center gap-1.5 sm:gap-2 px-3.5 sm:px-5 py-2 sm:py-2.5 rounded-full text-xs sm:text-sm font-medium transition-all duration-200 select-none ${
            i === 0
              ? 'bg-gradient-to-r from-blue-600 to-blue-800 text-white shadow-lg shadow-blue-200/40 scale-105'
              : 'bg-white text-slate-600 border border-slate-200/70 hover:border-blue-300 hover:text-blue-600 hover:shadow-sm'
          }`}
        >
          <span>{cat.name}</span>
        </button>
      ))}
    </div>
  </div>
</section>
