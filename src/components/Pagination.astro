---
const { locale = 'zh' } = Astro.props
const isEn = locale === 'en'
const prevLabel = isEn ? 'Prev' : '上一页'
const nextLabel = isEn ? 'Next' : '下一页'
---

<div id="pagination" class="flex items-center justify-center gap-2 mt-8 hidden">
  <button id="page-prev" data-page="prev" class="px-3 py-2 text-sm font-medium text-slate-500 bg-white border border-slate-200/70 rounded-lg hover:text-blue-600 hover:border-blue-300 transition-colors disabled:opacity-40 disabled:cursor-not-allowed dark:bg-slate-800 dark:text-slate-400 dark:border-slate-600/70 dark:hover:text-blue-400">
    {prevLabel}
  </button>
  <div id="page-numbers" class="flex items-center gap-1"></div>
  <button id="page-next" data-page="next" class="px-3 py-2 text-sm font-medium text-slate-500 bg-white border border-slate-200/70 rounded-lg hover:text-blue-600 hover:border-blue-300 transition-colors disabled:opacity-40 disabled:cursor-not-allowed dark:bg-slate-800 dark:text-slate-400 dark:border-slate-600/70 dark:hover:text-blue-400">
    {nextLabel}
  </button>
</div>
