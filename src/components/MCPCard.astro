---
const { mcp, locale = 'zh' } = Astro.props
const prefix = `${import.meta.env.BASE_URL}/${locale}`

const categoryColors = {
  'file-system': 'bg-cyan-100 text-cyan-700',
  database: 'bg-blue-100 text-blue-700',
  api: 'bg-purple-100 text-purple-700',
  search: 'bg-green-100 text-green-700',
  compute: 'bg-orange-100 text-orange-700',
}

const categoryNames = {
  'file-system': { zh: '文件系统', en: 'File System' },
  'database': { zh: '数据库', en: 'Database' },
  'api': { zh: 'API', en: 'API' },
  'search': { zh: '搜索', en: 'Search' },
  'compute': { zh: '计算', en: 'Compute' },
}

const typeLabels = {
  stdio: { zh: '本地', en: 'Local' },
  http: { zh: '网络', en: 'Network' },
  websocket: { zh: '实时', en: 'Realtime' },
}

const catName = categoryNames[mcp.category]?.[locale] || ''
const catColor = categoryColors[mcp.category] || 'bg-slate-100 text-slate-600'
const typeLabel = typeLabels[mcp.serverType] || { zh: mcp.serverType, en: mcp.serverType }
const stars = Math.round(mcp.rating)
const featureText = locale === 'en' ? 'Featured' : '精选推荐'
const reviewText = locale === 'en' ? 'reviews' : '评价'
---

<a href={`${prefix}/mcps/${mcp.slug}`} class="block group glass rounded-2xl p-5 sm:p-6 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-slate-200/60 dark:hover:shadow-slate-900/60 cursor-pointer">
  {mcp.featured ? (
    <div class="flex items-center mb-3">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-semibold text-amber-600 bg-amber-50 rounded-full">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {featureText}
      </span>
    </div>
  ) : null}

  <h3 class="text-base sm:text-lg font-semibold text-slate-800 dark:text-slate-100 mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-1">{mcp.name}</h3>

  <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-4 line-clamp-2">{mcp.description}</p>

  <div class="flex items-center gap-2 mb-4 flex-wrap">
    <span class={`px-2.5 py-0.5 text-xs font-medium rounded-full ${catColor}`}>{catName}</span>
    <span class="px-2.5 py-0.5 text-xs font-medium rounded-full bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300">{typeLabel[locale]}</span>
  </div>

  <div class="flex items-center gap-1.5 mb-4">
    <div class="flex items-center">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg class={`w-3.5 h-3.5 ${i < stars ? 'text-amber-400' : 'text-slate-200'}`} viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
    </div>
    <span class="text-sm font-semibold text-slate-700 dark:text-slate-300">{mcp.rating}</span>
    <span class="text-xs text-slate-400 dark:text-slate-500">({mcp.reviewCount} {reviewText})</span>
  </div>

  <div class="flex items-center flex-wrap gap-1.5 pt-4 border-t border-slate-100 dark:border-slate-700">
    {mcp.modelCompatibility.map(m => (
      <span class="px-2 py-0.5 text-xs font-medium text-slate-500 bg-slate-100 rounded-md dark:text-slate-400 dark:bg-slate-700">{m}</span>
    ))}
  </div>
</a>
