---
const { skill, locale = 'zh' } = Astro.props
const prefix = `${import.meta.env.BASE_URL}/${locale}`

const categoryColors = {
  ai: 'bg-blue-100 text-blue-700',
  programming: 'bg-blue-100 text-blue-700',
  design: 'bg-pink-100 text-pink-700',
  writing: 'bg-orange-100 text-orange-700',
  marketing: 'bg-green-100 text-green-700',
  management: 'bg-cyan-100 text-cyan-700',
  data: 'bg-yellow-100 text-yellow-700',
  language: 'bg-teal-100 text-teal-700',
  growth: 'bg-rose-100 text-rose-700',
}

const categoryNameMap = {
  ai: { zh: 'AI / 大模型', en: 'AI / LLM' },
  programming: { zh: '编程开发', en: 'Programming' },
  design: { zh: 'UI/UX 设计', en: 'UI/UX Design' },
  writing: { zh: '内容创作', en: 'Content Creation' },
  marketing: { zh: '市场营销', en: 'Marketing' },
  management: { zh: '管理', en: 'Management' },
  data: { zh: '数据分析', en: 'Data Analysis' },
  language: { zh: '语言学习', en: 'Language' },
  growth: { zh: '个人成长', en: 'Personal Growth' },
}

const difficultyMap = {
  1: { label: { zh: '初级', en: 'Beginner' }, cls: 'text-emerald-600 bg-emerald-50' },
  2: { label: { zh: '中级', en: 'Intermediate' }, cls: 'text-amber-600 bg-amber-50' },
  3: { label: { zh: '高级', en: 'Advanced' }, cls: 'text-rose-600 bg-rose-50' },
}

const catName = categoryNameMap[skill.category]?.[locale] || ''
const catColor = categoryColors[skill.category] || 'bg-slate-100 text-slate-600'
const diff = difficultyMap[skill.difficulty] || difficultyMap[1]
const stars = Math.round(skill.rating)
const featureText = locale === 'en' ? 'Featured' : '精选推荐'
const reviewText = locale === 'en' ? 'reviews' : '评'
---

<a href={`${prefix}/skills/${skill.slug}`} class="block group glass rounded-2xl p-5 sm:p-6 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-slate-200/60 dark:hover:shadow-slate-900/60 cursor-pointer">
  {skill.featured ? (
    <div class="flex items-center mb-3">
      <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-semibold text-amber-600 bg-amber-50 rounded-full">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {featureText}
      </span>
    </div>
  ) : null}

  <h3 class="text-base sm:text-lg font-semibold text-slate-800 dark:text-slate-100 mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-1">{skill.name}</h3>

  <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed mb-4 line-clamp-2">{skill.description}</p>

  <div class="flex items-center gap-2 mb-4 flex-wrap">
    <span class={`px-2.5 py-0.5 text-xs font-medium rounded-full ${catColor}`}>{catName}</span>
    <span class={`px-2.5 py-0.5 text-xs font-medium rounded-full ${diff.cls}`}>{diff.label[locale]}</span>
  </div>

  <div class="flex items-center gap-1.5 mb-4">
    <div class="flex items-center">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg class={`w-3.5 h-3.5 ${i < stars ? 'text-amber-400' : 'text-slate-200'}`} viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
    </div>
    <span class="text-sm font-semibold text-slate-700 dark:text-slate-300">{skill.rating}</span>
    <span class="text-xs text-slate-400 dark:text-slate-500">({skill.reviewCount} {reviewText})</span>
  </div>

  <div class="flex items-center pt-4 border-t border-slate-100 dark:border-slate-700">
    <span class="text-sm text-slate-600 dark:text-slate-300 font-medium">{skill.author.name}</span>
  </div>
</a>
